// TextDummy - Jenkins Pipeline
// Copy to repo root as "Jenkinsfile" and adjust parameters/stages.
//
// CLI supports:
//   --ci       → no colors, quiet, JSON output, exit codes
//   run_api()  → programmatic Python API (CLIResult dataclass)
//
// Exit codes: 0=success, 1=runtime error, 2=usage error

pipeline {
    agent any
    parameters {
        choice(name: 'LOCALE', choices: ['es_ES', 'en_US', 'en_GB', 'pt_BR', 'pt_PT', 'fr_FR', 'de_DE', 'it_IT'], description: 'Data generation locale')
        string(name: 'COUNT', defaultValue: '100', description: 'Number of records to generate')
        string(name: 'TYPES', defaultValue: 'first_name,last_name,email', description: 'Comma-separated data types for batch')
        string(name: 'OUTPUT_FILE', defaultValue: 'output/fake_data.csv', description: 'Output file path')
        choice(name: 'FORMAT', choices: ['table', 'json', 'csv', 'summary', 'quiet'], description: 'Output format')
        booleanParam(name: 'DRY_RUN', defaultValue: false, description: 'Simulate without changes')
        booleanParam(name: 'RUN_LINT', defaultValue: true, description: 'Run linter')
        booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Run test suite')
    }
    environment {
        PYTHONPATH = '.'
        PYTHONIOENCODING = 'utf-8'
        NO_COLOR = '1'
    }
    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
    }
    stages {
        stage('Setup') {
            steps {
                sh 'pip install uv && uv sync --quiet'
            }
        }
        stage('Lint') {
            when { expression { params.RUN_LINT } }
            steps {
                sh 'uv run ruff check shadetriptxt/text_dummy/'
            }
        }
        stage('Test') {
            when { expression { params.RUN_TESTS } }
            steps {
                sh 'uv run pytest tests/ -v --no-color --tb=short --junitxml=reports/junit.xml'
            }
            post {
                always { junit 'reports/junit.xml' }
            }
        }
        stage('Generate Batch') {
            steps {
                sh """uv run python -m shadetriptxt.text_dummy.cli batch \
                       --types ${params.TYPES} \
                       --count ${params.COUNT} \
                       --locale ${params.LOCALE} \
                       --format ${params.FORMAT} \
                       --ci \
                       -o ${params.OUTPUT_FILE} \
                       ${params.DRY_RUN ? '--dry-run' : ''}"""
            }
        }
        stage('Generate Profiles') {
            steps {
                sh '''uv run python -m shadetriptxt.text_dummy.cli profile \
                       --count 50 \
                       --locale es_ES \
                       --ci \
                       -o output/profiles.json'''
            }
        }
        stage('Generate ID Documents') {
            steps {
                sh '''uv run python -m shadetriptxt.text_dummy.cli id-doc \
                       --count 50 \
                       --locale es_ES \
                       --ci \
                       -o output/id_documents.json'''
            }
        }
        stage('Verify') {
            steps {
                sh 'ls -la output/'
                sh 'test -s ${OUTPUT_FILE} || exit 1'
            }
        }
        stage('API Test') {
            steps {
                sh '''uv run python -c "
from shadetriptxt.text_dummy.cli import run_api
result = run_api(['generate', '--type', 'first_name', '--locale', 'es_ES'])
assert result.ok, f'API call failed: {result.error}'
print(f'Stats: {result.stats}')
"'''
            }
        }
    }
    post {
        success {
            archiveArtifacts artifacts: 'output/**,reports/**', fingerprint: true
        }
        failure {
            echo 'Data generation pipeline failed — check stage logs above'
        }
        cleanup {
            cleanWs()
        }
    }
}
