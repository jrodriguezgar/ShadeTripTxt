// TextMatcher - Jenkins Pipeline
// Copy to repo root as "Jenkinsfile" and adjust parameters/stages.
//
// CLI supports:
//   --ci       → no colors, quiet, JSON output, exit codes
//   run_api()  → programmatic Python API (CLIResult dataclass)
//
// Exit codes: 0=success, 1=runtime error, 2=usage error

pipeline {
    agent any
    parameters {
        choice(name: 'PRESET', choices: ['default', 'strict', 'lenient', 'fuzzy'], description: 'Matching preset')
        string(name: 'THRESHOLD', defaultValue: '0.8', description: 'Minimum similarity threshold')
        choice(name: 'LOCALE', choices: ['es_ES', 'en_US', 'en_GB', 'pt_BR', 'pt_PT', 'fr_FR', 'de_DE', 'it_IT'], description: 'Processing locale')
        string(name: 'INPUT_FILE', defaultValue: 'data/names_to_dedup.txt', description: 'Input file path')
        string(name: 'OUTPUT_FILE', defaultValue: 'output/dedup_results.json', description: 'Output file path')
        choice(name: 'FORMAT', choices: ['table', 'json', 'csv', 'summary', 'quiet'], description: 'Output format')
        booleanParam(name: 'DRY_RUN', defaultValue: false, description: 'Simulate without changes')
        booleanParam(name: 'RUN_LINT', defaultValue: true, description: 'Run linter')
        booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Run test suite')
    }
    environment {
        PYTHONPATH = '.'
        PYTHONIOENCODING = 'utf-8'
        NO_COLOR = '1'
    }
    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
    }
    stages {
        stage('Setup') {
            steps {
                sh 'pip install uv && uv sync --quiet'
            }
        }
        stage('Lint') {
            when { expression { params.RUN_LINT } }
            steps {
                sh 'uv run ruff check shadetriptxt/text_matcher/'
            }
        }
        stage('Test') {
            when { expression { params.RUN_TESTS } }
            steps {
                sh 'uv run pytest tests/ -v --no-color --tb=short --junitxml=reports/junit.xml'
            }
            post {
                always { junit 'reports/junit.xml' }
            }
        }
        stage('Batch Compare') {
            steps {
                sh """uv run python -m shadetriptxt.text_matcher.cli batch \
                       --input ${params.INPUT_FILE} \
                       --preset ${params.PRESET} \
                       --threshold ${params.THRESHOLD} \
                       --locale ${params.LOCALE} \
                       --format ${params.FORMAT} \
                       --ci \
                       -o ${params.OUTPUT_FILE} \
                       ${params.DRY_RUN ? '--dry-run' : ''}"""
            }
        }
        stage('Duplicate Detection') {
            steps {
                sh """uv run python -m shadetriptxt.text_matcher.cli duplicates \
                       --input ${params.INPUT_FILE} \
                       --preset ${params.PRESET} \
                       --threshold ${params.THRESHOLD} \
                       --ci \
                       -o output/duplicates.json"""
            }
        }
        stage('Name Comparison') {
            steps {
                sh """uv run python -m shadetriptxt.text_matcher.cli compare-names \
                       'García López, Juan' 'GARCIA LOPEZ JUAN' \
                       --preset ${params.PRESET} \
                       --ci"""
            }
        }
        stage('Verify') {
            steps {
                sh 'ls -la output/'
                sh 'test -s ${OUTPUT_FILE} || exit 1'
            }
        }
        stage('API Test') {
            steps {
                sh '''uv run python -c "
from shadetriptxt.text_matcher.cli import run_api
result = run_api(['compare', 'García', 'Garcia'])
assert result.ok, f'API call failed: {result.error}'
print(f'Stats: {result.stats}')
"'''
            }
        }
    }
    post {
        success {
            archiveArtifacts artifacts: 'output/**,reports/**', fingerprint: true
        }
        failure {
            echo 'Matching pipeline failed — check stage logs above'
        }
        cleanup {
            cleanWs()
        }
    }
}
